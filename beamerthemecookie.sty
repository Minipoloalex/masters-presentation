% -----------------------------------------------------------------------------
% Gentle defaults for optional packages, applied only when they are loaded.
% -----------------------------------------------------------------------------
\BeforeBeginEnvironment{tabular}{\renewcommand{\arraystretch}{1.12}}
\newcommand{\cookie@setuplistingstyle}{%
  \@ifpackageloaded{listings}{%
    \lstdefinestyle{cookiebase}{
      basicstyle=\ttfamily\small,
      numbers=none,
      breaklines=true,
      breakatwhitespace=false,
      columns=fullflexible,
      keepspaces=true,
      showstringspaces=false,
      tabsize=2,
      keywordstyle=\color{cookieAccent}\bfseries,
      commentstyle=\color{cookieMuted}\itshape,
      stringstyle=\color{cookieExample},
      emphstyle=\color{cookieAlert}\bfseries
    }%
    \lstdefinestyle{cookie}{
      style=cookiebase,
      backgroundcolor=\color{cookieAccent!4},
      frame=single,
      rulecolor=\color{cookieLine},
      framerule=.5pt,
      framesep=2mm,
      xleftmargin=.4mm,
      xrightmargin=.4mm
    }%
    \lstdefinestyle{cookiebare}{
      style=cookiebase,
      frame=none,
      backgroundcolor={},
      xleftmargin=0pt,
      xrightmargin=0pt
    }%
  }{}%
}
\cookie@setuplistingstyle
\AtBeginDocument{%
  \cookie@applynotes
  \cookie@setupalgorithm
  \hypersetup{
    linkcolor=cookieAccent,
    urlcolor=cookieAccent,
    citecolor=cookieAccent
  }%
  \cookie@setuplistingstyle
  \@ifpackageloaded{minted}{\setminted{breaklines,fontsize=\small}}{}%
}

