% -----------------------------------------------------------------------------
% Fonts: no bundled font files; use installed system fonts with safe fallbacks.
% -----------------------------------------------------------------------------
\newcommand{\cookie@setuplibertinusmath}{%
  \ifPDFTeX
    \PackageWarning{beamerthemecookie}{Libertinus Math requires LuaLaTeX or XeLaTeX; using Beamer's default math fonts}%
  \else
    \IfFileExists{unicode-math.sty}{%
      \RequirePackage{fontspec}%
      \RequirePackage{unicode-math}%
      \usefonttheme{professionalfonts}%
      \IfFileExists{LibertinusMath-Regular.otf}{%
        \setmathfont{LibertinusMath-Regular.otf}[BoldFont=LibertinusMath-Regular.otf]%
      }{%
        \IfFontExistsTF{Libertinus Math}{%
          \setmathfont{Libertinus Math}%
        }{%
          \PackageWarning{beamerthemecookie}{Libertinus Math not found; using unicode-math's default math font}%
        }%
      }%
    }{%
      \PackageWarning{beamerthemecookie}{unicode-math.sty not found; using Beamer's default math fonts}%
    }%
  \fi
}

\newcommand{\cookie@setupmathfonts}{%
  \ifdefstring{\cookie@mathfonts}{libertinus}{%
    \cookie@setuplibertinusmath
  }{}%
}
\cookie@setupmathfonts

\newcommand{\cookie@setupfonts}{%
  \ifdefstring{\cookie@fonts}{auto}{%
    \ifPDFTeX
      \RequirePackage[T1]{fontenc}%
      \IfFileExists{FiraSans.sty}{\RequirePackage[sfdefault]{FiraSans}}{\RequirePackage{lmodern}}%
    \else
      \RequirePackage{fontspec}%
      \defaultfontfeatures{Ligatures=TeX,Scale=MatchLowercase}%
      \IfFileExists{NotoSans-Regular.ttf}{%
        \setmainfont{NotoSans-Regular.ttf}[
          BoldFont=NotoSans-Bold.ttf,
          ItalicFont=NotoSans-Italic.ttf,
          BoldItalicFont=NotoSans-BoldItalic.ttf
        ]%
        \setsansfont{NotoSans-Regular.ttf}[
          BoldFont=NotoSans-Bold.ttf,
          ItalicFont=NotoSans-Italic.ttf,
          BoldItalicFont=NotoSans-BoldItalic.ttf
        ]%
      }{%
        \IfFontExistsTF{Noto Sans}{%
          \setmainfont{Noto Sans}%
          \setsansfont{Noto Sans}%
        }{%
          \IfFontExistsTF{TeX Gyre Heros}{\setmainfont{TeX Gyre Heros}\setsansfont{TeX Gyre Heros}}{}%
        }%
      }%
      \IfFileExists{NotoSansMono-Regular.ttf}{%
        \setmonofont{NotoSansMono-Regular.ttf}[
          Scale=0.90,
          BoldFont=NotoSansMono-Bold.ttf,
          ItalicFont=NotoSansMono-Regular.ttf,
          BoldItalicFont=NotoSansMono-Bold.ttf
        ]%
      }{%
        \IfFontExistsTF{Noto Sans Mono}{%
          \setmonofont{Noto Sans Mono}[Scale=0.90]%
        }{%
          \IfFontExistsTF{DejaVu Sans Mono}{\setmonofont{DejaVu Sans Mono}[Scale=0.90]}{}%
        }%
      }%
    \fi
    \renewcommand{\familydefault}{\sfdefault}%
  }{}%
}
\cookie@setupfonts

