  \immediate\write\@auxout{\string\gdef\string\cookie@totalsections{\the\beamer@tocsectionnumber}}%
}

% Track subsection totals per section in the auxiliary file.  This lets the
% subsection interstitial show meaningful local progress instead of reusing the
% deck-wide frame counter.
\newcommand{\cookie@writesubsectiontotal}{%
  \ifnum\value{section}>0\relax
    \immediate\write\@auxout{%
      \string\expandafter\string\gdef
      \string\csname\space cookie@subsections@\arabic{section}\string\endcsname
      {\arabic{subsection}}%
    }%
  \fi
}
\pretocmd{\section}{\cookie@writesubsectiontotal}{}{%
  \PackageWarning{beamerthemecookie}{Could not patch \string\section; subsection totals may be unavailable}%
}
\AtEndDocument{\cookie@writesubsectiontotal}

\newcommand{\cookie@subsectiontotal}{%
  \ifcsdef{cookie@subsections@\arabic{section}}{%
    \csuse{cookie@subsections@\arabic{section}}%
  }{%
    \insertsubsectionnumber
  }%
}

\newdimen\cookie@subsectionbarwidth
\cookie@subsectionbarwidth=.30\paperwidth
\newcommand{\cookie@subsectionprogress}{%
  \@tempcnta=\cookie@subsectiontotal\relax
  \ifnum\@tempcnta<\value{subsection}\relax\@tempcnta=\value{subsection}\relax\fi
  \cookie@progresswidth=\cookie@subsectionbarwidth
  \divide\cookie@progresswidth by \@tempcnta
  \multiply\cookie@progresswidth by \value{subsection}
  \begin{tikzpicture}[baseline]
    \fill[cookieProgressShade] (0,0) rectangle (\cookie@subsectionbarwidth,.045cm);
    \fill[cookieProgressLine] (0,0) rectangle (\cookie@progresswidth,.045cm);
  \end{tikzpicture}%
}

\newcommand{\cookie@sectionprogress}{%
  \@tempcnta=\cookie@totalsections\relax
  \ifnum\@tempcnta<\insertsectionnumber\relax\@tempcnta=\insertsectionnumber\relax\fi
  \cookie@progresswidth=\cookie@sectionbarwidth
  \divide\cookie@progresswidth by \@tempcnta
  \multiply\cookie@progresswidth by \insertsectionnumber
  \begin{tikzpicture}[baseline]
    \fill[cookieProgressShade] (0,0) rectangle (\cookie@sectionbarwidth,.055cm);
    \fill[cookieProgressLine] (0,0) rectangle (\cookie@progresswidth,.055cm);
  \end{tikzpicture}%
}

\newcommand{\cookie@sectionpageframe}{%
  \begin{frame}[plain,noframenumbering,c]
    \begin{tikzpicture}[remember picture,overlay]
      \fill[cookieTitleBar]
        (current page.south west) rectangle ($(current page.north west)+(.012\paperwidth,0)$);
      \node[anchor=base west,text=themeColorFive,font=\fontsize{28}{28}\selectfont\bfseries]
        at ($(current page.west)+(.070\paperwidth,.012\paperheight)$) {\insertsectionnumber};
      \node[anchor=base west,text width=.70\paperwidth,align=left]
        at ($(current page.west)+(.150\paperwidth,.012\paperheight)$)
        {{\usebeamerfont{section title}\usebeamercolor[fg]{section title}\cookie@format{\insertsectionhead}}};
      \ifdefstring{\cookie@sectionpage}{progressbar}{%
        \node[anchor=west] at ($(current page.west)+(.070\paperwidth,-.130\paperheight)$) {\cookie@sectionprogress};
      }{}%
    \end{tikzpicture}
  \end{frame}%
}

\newcommand{\cookie@subsectionpageframe}{%
  \begin{frame}[plain,noframenumbering,c]
    \begin{tikzpicture}[remember picture,overlay]
      % The airy 0.3 composition, with one horizontal signal instead of two.
      \fill[cookieTitleBar]
        (current page.south west) rectangle ($(current page.north west)+(.012\paperwidth,0)$);

      \node[anchor=west,text=themeColorFive,font=\fontsize{7.5}{9}\selectfont\bfseries]
        at ($(current page.west)+(.085\paperwidth,.145\paperheight)$)
        {SECTION~\insertsectionnumber\hspace{.65em}\textcolor{cookieLine}{/}\hspace{.65em}\MakeUppercase{\insertsectionhead}};

      \node[anchor=west,text width=.58\paperwidth,align=left]
        at ($(current page.west)+(.085\paperwidth,.005\paperheight)$)
        {{\usebeamerfont{subsection title}\usebeamercolor[fg]{subsection title}%
          \cookie@format{\insertsubsectionhead}}};

      \ifdefstring{\cookie@subsectionpage}{progressbar}{%
        % Here the local progress bar is also the underline.
        \node[anchor=west] at ($(current page.west)+(.085\paperwidth,-.205\paperheight)$)
          {\cookie@subsectionprogress};
        \node[anchor=west,text=themeColorFive,font=\fontsize{6.8}{8}\selectfont\bfseries]
          at ($(current page.west)+(.405\paperwidth,-.205\paperheight)$)
          {\insertsubsectionnumber\,/\,\cookie@subsectiontotal};
      }{%
        \draw[cookieAccent,line width=1.4pt]
          ($(current page.west)+(.085\paperwidth,-.145\paperheight)$)
          -- ($(current page.west)+(.185\paperwidth,-.145\paperheight)$);
      }%

      \node[anchor=east,text=themeColorFive!12,font=\fontsize{58}{58}\selectfont\bfseries]
        at ($(current page.east)+(-.070\paperwidth,.225\paperheight)$)
        {\insertsectionnumber.\insertsubsectionnumber};
    \end{tikzpicture}
  \end{frame}%
}

\AtBeginSection[]{%
  \ifdefstring{\cookie@sectionpage}{none}{}{\cookie@sectionpageframe}%
}
\AtBeginSubsection[]{%
  \ifdefstring{\cookie@subsectionpage}{none}{}{\cookie@subsectionpageframe}%
}

% -----------------------------------------------------------------------------
% Overlay helpers and modal cards
% -----------------------------------------------------------------------------
% Standard Beamer overlays work unchanged. These helpers keep common narrative
% patterns compact and preserve the modal syntax used by awesome-beamer decks.
\newcommand<>{\cookiereveal}[1]{\uncover#2{#1}}
\newcommand<>{\cookiefocus}[1]{%
  \alt#2{#1}{{\color{cookieMuted!62}#1}}%
}

\newenvironment<>{cookiemodal}[1][]{%
  \def\cookie@modaltitle{#1}%
  \begin{visibleenv}#2%
  \begin{tikzpicture}[remember picture,overlay]
    \fill[cookie modal backdrop]
      (current page.south west) rectangle (current page.north east);
    \node[cookie modal box] (cookie@modalcontent) at (current page.center) \bgroup
      \begin{minipage}{.68\paperwidth}
        \color{cookieInk}%
        \ifblank{#1}{}{\vspace*{.35em}}%
        \ignorespaces
}{%
        \unskip
      \end{minipage}
    \egroup;
    \ifblank{\cookie@modaltitle}{}{%
      \node[cookie modal title,anchor=center]
        at (cookie@modalcontent.north) {\cookie@modaltitle};%
    }%
  \end{tikzpicture}%
  \end{visibleenv}%
}

% Compatibility alias: \begin{modal}<2>[Title] ... \end{modal}
\@ifundefined{modal}{%
  \let\modal\cookiemodal
  \let\endmodal\endcookiemodal
}{%
  \PackageWarning{beamerthemecookie}{Environment `modal' already defined; use `cookiemodal'}%
}

% -----------------------------------------------------------------------------
% Standout / plain frames
% -----------------------------------------------------------------------------
\newif\ifcookie@standoutframe
\define@key{beamerframe}{standout}[true]{%
  \global\cookie@standoutframetrue
  \begingroup
  \let\cookie@savedKVprefix\KV@prefix
  \beamer@plainframetrue
  \def\beamer@frametemplate{\beamer@frametemplate@plain}%
  \beamer@frametopskip=0pt plus 1fill\relax
  \beamer@framebottomskip=0pt plus 1.5fill\relax
  \beamer@frametopskipautobreak=0pt plus .4\paperheight\relax
  \beamer@framebottomskipautobreak=0pt plus .6\paperheight\relax
  \setbeamercolor{background canvas}{bg=cookieAccent}%
  \setbeamercolor{normal text}{fg=white,bg=cookieAccent}%
  \setbeamercolor{structure}{fg=white}%
  \setbeamercolor{alerted text}{fg=white}%
  \setbeamertemplate{frametitle}{}%
  \setbeamertemplate{footline}{}%
  \centering
  \usebeamerfont{standout}%
  \color{white}%
  \let\KV@prefix\cookie@savedKVprefix
}

% Beamer processes frame keys before the frame body. The explicit group keeps
% the standout colors, font selection, and empty templates local to one frame.
\apptocmd{\beamer@reseteecodes}{%
  \ifcookie@standoutframe
    \endgroup
    \global\cookie@standoutframefalse
  \fi
}{}{%
  \PackageWarning{beamerthemecookie}{Could not patch \string\beamer@reseteecodes; standout frame state may leak}%
}

\newcommand{\cookieplain}[2][cookieAccent]{%
  \begingroup\colorlet{cookieAccent}{#1}%
  \begin{frame}[noframenumbering,standout]#2\end{frame}%
  \endgroup
}

% Full-width content helper; unlike the old theme this does not alter global
% Beamer margins or depend on frame internals.
\newenvironment{wide}{%
  \par\begingroup
  \hspace*{\dimexpr-\beamer@leftmargin+.035\paperwidth\relax}%
  \begin{minipage}{.91\paperwidth}%
}{%
  \end{minipage}\endgroup\par
}

