% A listings-backed code card.  The language is the mandatory argument; all
% ordinary tcolorbox keys (for example title=...) remain available.
\newtcblisting{cookiecode}[2][]{%
  enhanced,
  listing only,
  listing engine=listings,
  listing options={style=cookiebare,language=#2},
  colback=cookieSoft!72!cookiePaper,
  colframe=cookieLine,
  coltext=cookieInk,
  colbacktitle=cookieAccent!12,
  coltitle=cookieInk,
  fonttitle=\bfseries\small,
  boxrule=.55pt,
  arc=1.6mm,
  outer arc=1.6mm,
  left=1.5mm,
  right=1.5mm,
  top=1.2mm,
  bottom=1.2mm,
  before skip=.45em,
  after skip=.45em,
  #1
}

% -----------------------------------------------------------------------------
% Algorithms
% -----------------------------------------------------------------------------
\newcommand{\cookiealgokw}[1]{\textcolor{cookieAlgorithmKeyword}{\bfseries\sffamily #1}}
\newcommand{\cookiealgoarg}[1]{\emph{#1}}
\newcommand{\cookiealgofunc}[1]{\textsc{#1}}
\newcommand{\cookiealgodata}[1]{\textsf{#1}}
\newcommand{\cookiealgonumber}[1]{\textcolor{cookieAlgorithmNumber}{#1}}
\newcommand{\cookiealgocomment}[1]{{\footnotesize\sffamily\itshape\textcolor{cookieAlgorithmComment}{#1}}}

\newcommand{\cookie@setupalgorithm}{%
  \ifcookie@algorithmavailable
    \RestyleAlgo{ruled}%
    \SetAlgoVlined
    \LinesNumbered
    \SetAlFnt{\small}%
    \SetKwSty{cookiealgokw}%
    \SetArgSty{cookiealgoarg}%
    \SetFuncSty{cookiealgofunc}%
    \SetDataSty{cookiealgodata}%
    \SetCommentSty{cookiealgocomment}%
    \SetNoFillComment
    \SetNlSty{cookiealgonumber}{\scriptsize\sffamily}{}%
    \SetAlgoNlRelativeSize{-1}%
    \SetAlgoInsideSkip{smallskip}%
    \SetAlgoSkip{medskip}%
    \SetAlgoHangIndent{1.2em}%
    \SetAlCapFnt{\small\sffamily\bfseries}%
    \SetAlCapNameFnt{\small\sffamily}%
    \SetAlCapHSkip{0pt}%
    \SetAlgoCaptionLayout{centerline}%
    \SetAlgoCaptionSeparator{:}%
    \SetKwInput{KwIn}{Input}%
    \SetKwInput{KwOut}{Output}%
    \setlength{\algoheightrule}{0.6pt}%
    \setlength{\algotitleheightrule}{0.6pt}%
    \setlength{\interspacetitleruled}{4pt}%
    \setlength{\interspacealgoruled}{4pt}%
  \fi
}

