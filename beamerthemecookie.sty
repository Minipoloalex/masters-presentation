\newcommand{\makeagenda}[1][]{%
  \begin{frame}[plain,t]
    \begin{tikzpicture}[remember picture,overlay]
      \fill[cookiePaper] (current page.south west) rectangle (current page.north east);
      \fill[cookieTitleBar]
        (current page.south west)
        rectangle
        ($(current page.north west)+(.012\paperwidth,0)$);
      \node[anchor=west,text=cookieInk,font=\fontsize{30}{34}\selectfont\bfseries]
        at ($(current page.west)+(.070\paperwidth,-.010\paperheight)$) {Contents};
      \node[anchor=west,inner sep=0pt,text width=.49\paperwidth]
        at ($(current page.west)+(.405\paperwidth,0)$)
        {\begin{minipage}[t]{.49\paperwidth}
          \cookie@agendatoc[#1]%
        \end{minipage}};
    \end{tikzpicture}%
  \end{frame}%
}

\renewcommand{\maketitle}{%
  \ifbeamer@inframe
    \titlepage
    \ifdefstring{\cookie@toc}{aftertitle}{%
      \PackageWarning{beamerthemecookie}{toc=aftertitle ignored because \string\maketitle\space was used inside a frame; call \string\makeagenda\space after the frame}%
    }{}%
  \else
    \begin{frame}[plain,noframenumbering]
      \titlepage
    \end{frame}
    \ifdefstring{\cookie@toc}{aftertitle}{\makeagenda}{}%
  \fi
}

