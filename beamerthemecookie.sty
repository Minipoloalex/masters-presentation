\newcount\cookie@agendatotal
\newcount\cookie@agendasplit
\newcount\cookie@agendarightstart

\newcommand{\cookie@agendarendertoc}[1][]{%
  \ifblank{#1}{%
    \cookie@agendatotal=\cookie@totalsections\relax
    \ifnum\cookie@agendatotal>8\relax
      \cookie@agendasplit=\cookie@agendatotal
      \advance\cookie@agendasplit by 1\relax
      \divide\cookie@agendasplit by 2\relax
      \cookie@agendarightstart=\cookie@agendasplit
      \advance\cookie@agendarightstart by 1\relax
      \begin{minipage}[t]{.48\linewidth}
        \tableofcontents[hideallsubsections,sections={1-\number\cookie@agendasplit}]%
      \end{minipage}%
      \hfill
      \begin{minipage}[t]{.48\linewidth}
        \tableofcontents[hideallsubsections,sections={\number\cookie@agendarightstart-\number\cookie@agendatotal}]%
      \end{minipage}%
    \else
      \tableofcontents[hideallsubsections]%
    \fi
  }{%
    \tableofcontents[hideallsubsections,#1]%
  }%
}

\newcommand{\cookie@agendatoc}[1][]{%
  \begingroup
    \setbeamertemplate{section in toc}{%
      \par\vspace{.03em}%
      {\fontsize{17}{19.8}\selectfont\raggedright
        \hyphenpenalty=10000\exhyphenpenalty=10000
        \noindent
        \makebox[1.35em][r]{%
          \textcolor{themeColorFive}{\bfseries\inserttocsectionnumber}%
        }%
        \hspace{.78em}%
        \parbox[t]{.78\linewidth}{\textcolor{cookieInk}{\strut\inserttocsection\strut}}\par}%
      \par\vspace{.23em}%
    }%
    \setbeamertemplate{subsection in toc}{%
      {\fontsize{8.3}{10}\selectfont
        \noindent\hspace*{4.10em}%
        \hangindent=7.97em\hangafter=1%
        \makebox[3.05em][r]{%
          \textcolor{themeColorFive}{\fontsize{7.7}{9}\selectfont\bfseries
            \inserttocsectionnumber.\inserttocsubsectionnumber}%
        }%
        \hspace{.82em}%
        \textcolor{cookieMuted}{\strut\inserttocsubsection\strut}\par}%
      \par\vspace{.12em}%
    }%
    \cookie@agendarendertoc[#1]%
  \endgroup
}

% Frame-title number rail
\newdimen\cookie@frametitleleftmargin
\newdimen\cookie@frametitlerightmargin
\newdimen\cookie@numberrailwidth
\newdimen\cookie@frametitlegap
\newcommand{\cookie@setframetitledimensions}{%
  \cookie@frametitleleftmargin=.105\paperwidth
  \cookie@frametitlerightmargin=.055\paperwidth
  \cookie@numberrailwidth=.065\paperwidth
  \cookie@frametitlegap=.014\paperwidth
}
\cookie@setframetitledimensions
\newcommand{\cookie@setframetitlelayout}{%
  \cookie@setframetitledimensions
  \ifnum\value{section}>\beamer@tocsectionnumber\relax
    \cookie@numberrailwidth=0pt
    \cookie@frametitlegap=0pt
  \fi
}

\newcommand{\cookie@railnumber}{%
  \ifdefstring{\cookie@numberrail}{none}{}{%
    \ifnum\value{section}>0
      \ifnum\value{section}>\beamer@tocsectionnumber\relax
        % Starred sections are intentionally omitted from the structural rail.
      \else
        {\cookie@railsectioncolor\insertsectionnumber}%
        \ifdefstring{\cookie@numberrail}{subsection}{%
          \ifnum\value{subsection}>0{\cookie@railsubsectioncolor.\insertsubsectionnumber}\fi
        }{}%
      \fi
    \else
      % The rail is structural, not a duplicate page counter.  Introductory
      % frames (including the automatic agenda) therefore leave it empty.
    \fi
  }%
}

% Compact title band with natural height.  A real vertical box gives the
% title predictable top padding, while the subtitle simply increases the band
% before the divider is drawn.
\setbeamertemplate{frametitle}{%
  \nointerlineskip
  \cookie@setframetitlelayout
  \hbox to \textwidth{\hspace*{-\beamer@leftmargin}%
  \begin{beamercolorbox}[wd=\paperwidth,sep=0pt]{frametitle}%
    \vbox{%
      \vskip.18cm
      \hbox to \paperwidth{%
        \hskip\cookie@frametitleleftmargin
        \vtop{%
          \hsize=\cookie@numberrailwidth
          \usebeamerfont{number rail}%
          \makebox[\hsize][l]{%
            \adjustbox{max width=\hsize}{\strut\cookie@railnumber\strut}%
          }\par
        }%
        \hskip\cookie@frametitlegap
        \vtop{%
          \hsize=\dimexpr\paperwidth-\cookie@frametitleleftmargin-\cookie@numberrailwidth-\cookie@frametitlegap-\cookie@frametitlerightmargin\relax
          \raggedright
          {\usebeamerfont{frametitle}\cookie@format{\strut\insertframetitle\strut}\par}%
          \ifx\insertframesubtitle\@empty\else
            \vskip.04cm
            {\usebeamerfont{framesubtitle}\usebeamercolor[fg]{framesubtitle}%
              \strut\insertframesubtitle\strut\par}%
          \fi
        }%
        \hfil
      }%
      \vskip.16cm
    }%
  \end{beamercolorbox}\hss}%
  \par\nointerlineskip
  \hbox to \textwidth{\hspace*{-\beamer@leftmargin}%
  \ifdefstring{\cookie@progressbar}{frametitle}{%
    \hbox{\cookie@progressrule{\paperwidth}}%
  }{%
    \cookie@frametitledivider
  }\hss}%
}

