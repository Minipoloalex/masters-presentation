\newcommand{\cookiepenguin}[1][]{%
  \begin{tikzpicture}[baseline=-.55ex,#1]
    \ifcookie@penguinavailable
      \penguin[body=cookieInk,belly=cookiePaper,bill=cookieWarm,feet=cookieWarm]
    \else
      \fill[cookieInk] (0,1.05) ellipse[x radius=.58,y radius=.88];
      \fill[cookiePaper] (0,.78) ellipse[x radius=.40,y radius=.52];
      \fill[cookiePaper] (-.18,1.52) ellipse[x radius=.09,y radius=.13];
      \fill[cookiePaper] (.18,1.52) ellipse[x radius=.09,y radius=.13];
      \fill[cookieInk] (-.16,1.50) circle[radius=.035];
      \fill[cookieInk] (.16,1.50) circle[radius=.035];
      \fill[cookieWarm] (0,1.34) -- (-.14,1.46) -- (.14,1.46) -- cycle;
      \fill[cookieWarm] (-.27,.22) ellipse[x radius=.22,y radius=.07];
      \fill[cookieWarm] (.27,.22) ellipse[x radius=.22,y radius=.07];
    \fi
    \draw[cookieAccent,line width=1.05pt] (0,2.25) ellipse[x radius=.48,y radius=.10];
    \fill[cookieAccent]
      (0,.72) .. controls (-.18,.88) and (-.34,.68) .. (0,.42)
      .. controls (.34,.68) and (.18,.88) .. (0,.72) -- cycle;
  \end{tikzpicture}%
}

\newenvironment{cookiequote}[1][]{%
  \def\cookie@quoteauthor{#1}%
  \begin{tcolorbox}[
    enhanced,
    frame hidden,
    colback=cookieSoft!56!cookiePaper,
    coltext=cookieInk,
    borderline west={1.5pt}{0pt}{cookieAccent},
