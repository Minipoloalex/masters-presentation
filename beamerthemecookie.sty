% -----------------------------------------------------------------------------
% Progress bars
% -----------------------------------------------------------------------------
\newdimen\cookie@progresswidth
\newdimen\cookie@sectionbarwidth
\newdimen\cookie@globalprogresswidth
\newcount\cookie@activesectioncount
\newcount\cookie@activesubsectioncount
\cookie@sectionbarwidth=.58\paperwidth
\cookie@globalprogresswidth=.82\paperwidth

\newcommand{\cookie@computeprogress}[1]{%
  \cookie@progresswidth=0pt%
  \@tempcnta=\inserttotalframenumber\relax
  \@tempcntb=\insertframenumber\relax
  % On the first run Beamer may report a total smaller than the current frame.
  % Cap the ratio at 1 so the intermediate dimension never overflows.
  \ifnum\@tempcnta<\@tempcntb\relax\@tempcnta=\@tempcntb\relax\fi
  \ifnum\@tempcnta>0\relax
    \cookie@progresswidth=#1\relax
    \divide\cookie@progresswidth by \@tempcnta
    \multiply\cookie@progresswidth by \@tempcntb
  \fi
}

\newcommand{\cookie@progressrule}[1]{%
  \cookie@computeprogress{#1}%
  \begin{tikzpicture}[baseline]
    \path[use as bounding box] (0,-.055cm) rectangle (#1,.10cm);
    \clip (0,-.055cm) rectangle (#1,.10cm);
    \fill[cookieProgressShade] (0,0) rectangle (#1,.045cm);
    \fill[cookieProgressLine] (0,0) rectangle (\cookie@progresswidth,.045cm);
    \fill[cookieProgressLine] (\cookie@progresswidth,.0225cm) circle[radius=.055cm];
  \end{tikzpicture}%
}

\newcommand{\cookie@loadsectionnames}{%
  \begingroup
    \makeatletter
    \def\babel@toc##1##2\relax{}%
    \def\beamer@sectionintoc##1##2##3##4##5{%
      \expandafter\gdef\csname cookie@sectionname@##1\endcsname{##2}%
      \expandafter\xdef\csname cookie@sectionpage@##1\endcsname{##3}%
      \xdef\cookie@totalsections{##1}%
    }%
    \def\beamer@subsectionintoc##1##2##3##4##5##6{}%
    \IfFileExists{\jobname.toc}{\@input{\jobname.toc}}{}%
  \endgroup
}
\AtBeginDocument{\cookie@loadsectionnames}

\newcommand{\cookie@sectionname}[1]{%
  \ifcsdef{cookie@sectionname@#1}{\csuse{cookie@sectionname@#1}}{#1}%
}

\newcommand{\cookie@sectionlink}[2]{%
  \ifcsdef{cookie@sectionpage@#1}{%
    \hyperlink{Navigation\csuse{cookie@sectionpage@#1}}{#2}%
  }{#2}%
}

\newcommand{\cookie@subsectiontotalfor}[1]{%
  \ifcsdef{cookie@subsections@#1}{\csuse{cookie@subsections@#1}}{0}%
}

\newcommand{\cookie@globalprogressbar}{%
  \begingroup
    \@tempcnta=\cookie@totalsections\relax
    \ifnum\@tempcnta<1\relax\@tempcnta=1\relax\fi
    \cookie@activesectioncount=\value{section}\relax
    \ifnum\cookie@activesectioncount>\@tempcnta\relax
      \cookie@activesectioncount=\@tempcnta\relax
    \fi
    \begin{tikzpicture}[baseline]
      \path[use as bounding box] (0,-.06cm) rectangle (\cookie@globalprogresswidth,.13cm);
      \pgfmathsetlengthmacro{\cookie@sectorwidth}{\cookie@globalprogresswidth/\the\@tempcnta}
      \foreach \cookie@sectionindex in {1,...,\the\@tempcnta}{%
        \pgfmathsetlengthmacro{\cookie@sectorleft}{(\cookie@sectionindex-1)*\cookie@sectorwidth}
        \pgfmathsetlengthmacro{\cookie@sectorright}{\cookie@sectionindex*\cookie@sectorwidth}
        \fill[cookieProgressShade] (\cookie@sectorleft,0) rectangle (\cookie@sectorright,.045cm);
        \ifnum\cookie@sectionindex<\cookie@activesectioncount\relax
          \fill[cookieProgressLine] (\cookie@sectorleft,0) rectangle (\cookie@sectorright,.045cm);
        \fi
        \ifnum\cookie@sectionindex=\cookie@activesectioncount\relax
          \fill[themeColorFour!52!cookiePaper] (\cookie@sectorleft,0) rectangle (\cookie@sectorright,.045cm);
          \ifnum\value{section}>\@tempcnta\relax
            \fill[cookieProgressLine] (\cookie@sectorleft,0) rectangle (\cookie@sectorright,.045cm);
          \else
            \@tempcntb=\cookie@subsectiontotalfor{\cookie@sectionindex}\relax
            \ifnum\@tempcntb>0\relax
              \cookie@activesubsectioncount=\value{subsection}\relax
              \ifnum\cookie@activesubsectioncount>\@tempcntb\relax\cookie@activesubsectioncount=\@tempcntb\relax\fi
              \pgfmathsetlengthmacro{\cookie@activewidth}{\cookie@sectorwidth*\the\cookie@activesubsectioncount/\the\@tempcntb}
              \fill[cookieProgressLine] (\cookie@sectorleft,0) rectangle ($(\cookie@sectorleft,0)+(\cookie@activewidth,.045cm)$);
            \else
              \fill[cookieProgressLine] (\cookie@sectorleft,0) rectangle (\cookie@sectorright,.045cm);
            \fi
          \fi
        \fi
      }%
      \foreach \cookie@sectionindex in {1,...,\the\@tempcnta}{%
        \pgfmathsetlengthmacro{\cookie@sectorright}{\cookie@sectionindex*\cookie@sectorwidth}
        \ifnum\cookie@sectionindex<\@tempcnta\relax
          \draw[cookieProgressLine!85!cookiePaper,line width=1.05pt] (\cookie@sectorright,-.020cm) -- (\cookie@sectorright,.072cm);
        \fi
      }%
      \foreach \cookie@sectionindex in {1,...,\the\@tempcnta}{%
        \pgfmathsetlengthmacro{\cookie@sectorleft}{(\cookie@sectionindex-1)*\cookie@sectorwidth}
        \pgfmathsetlengthmacro{\cookie@sectorright}{\cookie@sectionindex*\cookie@sectorwidth}
        \ifnum\cookie@sectionindex=\cookie@activesectioncount\relax
          \ifnum\value{section}>\@tempcnta\relax
            \pgfmathsetlengthmacro{\cookie@dotx}{\cookie@sectorright}
          \else
            \@tempcntb=\cookie@subsectiontotalfor{\cookie@sectionindex}\relax
            \ifnum\@tempcntb>0\relax
              \cookie@activesubsectioncount=\value{subsection}\relax
              \ifnum\cookie@activesubsectioncount>\@tempcntb\relax\cookie@activesubsectioncount=\@tempcntb\relax\fi
              \pgfmathsetlengthmacro{\cookie@activewidth}{\cookie@sectorwidth*\the\cookie@activesubsectioncount/\the\@tempcntb}
              \pgfmathsetlengthmacro{\cookie@dotx}{\cookie@sectorleft+\cookie@activewidth}
            \else
              \pgfmathsetlengthmacro{\cookie@dotx}{\cookie@sectorright}
            \fi
          \fi
          \fill[cookieProgressLine] (\cookie@dotx,.0225cm) circle[radius=.052cm];
        \fi
      }%
    \end{tikzpicture}%
  \endgroup
}

\newcommand{\cookie@globalprogresslabels}{%
  \begingroup
    \@tempcnta=\cookie@totalsections\relax
    \ifnum\@tempcnta<1\relax\@tempcnta=1\relax\fi
    \cookie@activesectioncount=\value{section}\relax
    \ifnum\cookie@activesectioncount>\@tempcnta\relax
      \cookie@activesectioncount=\@tempcnta\relax
    \fi
    \begin{tikzpicture}[baseline]
      \path[use as bounding box] (0,-.08cm) rectangle (\cookie@globalprogresswidth,.24cm);
      \pgfmathsetlengthmacro{\cookie@sectorwidth}{\cookie@globalprogresswidth/\the\@tempcnta}
      \foreach \cookie@sectionindex in {1,...,\the\@tempcnta}{%
        \pgfmathsetlengthmacro{\cookie@labelx}{(\cookie@sectionindex-.5)*\cookie@sectorwidth}
        \ifnum\cookie@sectionindex=\cookie@activesectioncount\relax
          \node[anchor=base,text=cookieProgressLine,font=\fontsize{5.9}{6.7}\selectfont\bfseries,align=center,text width=\dimexpr\cookie@sectorwidth-.45em\relax]
            at (\cookie@labelx,0) {\cookie@sectionlink{\cookie@sectionindex}{\cookie@sectionname{\cookie@sectionindex}}};
        \else
          \node[anchor=base,text=cookieMuted,font=\fontsize{5.7}{6.5}\selectfont,align=center,text width=\dimexpr\cookie@sectorwidth-.45em\relax]
            at (\cookie@labelx,0) {\cookie@sectionlink{\cookie@sectionindex}{\cookie@sectionname{\cookie@sectionindex}}};
        \fi
      }%
    \end{tikzpicture}%
  \endgroup
}

