% Frame keys are processed outside the body group in Beamer.  Reset the
% frame-local background state after shipout so a photo never leaks into the
% next slide.
\apptocmd{\beamer@reseteecodes}{%
  \ifcookie@backgroundframe
    \gdef\cookie@framebgimage{}%
    \gdef\cookie@framebgfit{cover}%
    \gdef\cookie@framebgopacity{1}%
    \gdef\cookie@framebgoverlay{cookieInk}%
    \gdef\cookie@framebgoverlayopacity{0}%
    \global\cookie@backgroundframefalse
  \fi
}{}{%
  \PackageWarning{beamerthemecookie}{Could not patch \string\beamer@reseteecodes; frame-local background state may leak}%
}

