\newcommand{\cookie@backgroundgraphic}[1]{%
  \ifdefstring{\cookie@framebgfit}{contain}{%
    \includegraphics[width=\paperwidth,height=\paperheight,keepaspectratio]{#1}%
  }{%
    \ifdefstring{\cookie@framebgfit}{stretch}{%
      \includegraphics[width=\paperwidth,height=\paperheight]{#1}%
    }{%
      \adjustbox{min size={\paperwidth}{\paperheight},center}{\includegraphics{#1}}%
    }%
  }%
}

\setbeamertemplate{background canvas}{%
  \begin{tikzpicture}[remember picture,overlay]
    \usebeamercolor{background canvas}%
    \fill[bg] (current page.south west) rectangle (current page.north east);
    \def\cookie@activebg{}%
    \ifdefempty{\cookie@framebgimage}{%
      \let\cookie@activebg\insertcookiebackgroundimage
    }{%
      \let\cookie@activebg\cookie@framebgimage
    }%
    \ifdefempty{\cookie@activebg}{}{%
      \begin{scope}
        \clip (current page.south west) rectangle (current page.north east);
        \node[anchor=center,inner sep=0,opacity=\cookie@framebgopacity]
          at (current page.center) {\cookie@backgroundgraphic{\cookie@activebg}};
        \fill[\cookie@framebgoverlay,opacity=\cookie@framebgoverlayopacity]
          (current page.south west) rectangle (current page.north east);
      \end{scope}
    }%
  \end{tikzpicture}%
}

