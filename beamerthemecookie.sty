% A clean note page for notes=show, notes=second, and notes=only. The presenter
% tool can provide current/next slide context, so the page focuses on prompts.
\setbeamertemplate{note page}{%
  \begin{tikzpicture}[remember picture,overlay]
    \fill[cookiePaper] (current page.south west) rectangle (current page.north east);
    \fill[cookieAccent] (current page.south west) rectangle ($(current page.north west)+(.014\paperwidth,0)$);
  \end{tikzpicture}%
  \begingroup\color{cookieInk}\usebeamerfont{note page}
  \vspace*{.005\paperheight}%
  \begin{minipage}[t]{.86\paperwidth}
    \vspace{0.1em}
    \cookiekicker{Speaker notes}\par\vspace{.15em}
    \hbox to .86\paperwidth{%
      \begin{minipage}[t]{.66\paperwidth}
        {\fontsize{18}{22}\selectfont\bfseries\insertshortframetitle\par}%
      \end{minipage}%
      \hfill
      \ifdefempty{\insertcookietargettime}{}{%
        \raisebox{.1em}{%
          \colorbox{cookieSoft}{%
            \hspace{.55em}\usebeamerfont{note time}\color{themeColorFive}%
            TARGET~\insertcookietargettime\hspace{.55em}%
          }%
        }%
      }%
    }%
    \vspace{.35em}
    {\footnotesize\color{cookieMuted}%
      \insertsectionhead%
      \ifx\insertsubsectionhead\@empty\else\hspace{.55em}/\hspace{.55em}\insertsubsectionhead\fi
    }%
  \end{minipage}%
  \par\vspace{.15em}
  {\color{cookieLine}\rule{\textwidth}{.45pt}}\par\vspace{.15em}
  \insertnote
  \endgroup
}

