        {{\fontsize{18}{22}\selectfont\bfseries\color{themeColorFive}\insertcookieclosingtext\par}};
      \draw[cookieProgressLine,line width=1.2pt]
        ($(current page.west)+(.070\paperwidth,-.105\paperheight)$)
        -- ($(current page.west)+(.285\paperwidth,-.105\paperheight)$);
