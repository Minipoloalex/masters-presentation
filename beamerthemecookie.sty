% Full-canvas background images.  The global command applies to subsequent
% frames; frame keys override it locally.  A dark or light translucent wash
% keeps photo treatment separate from the source image.
\newif\ifcookie@backgroundframe
\cookie@backgroundframefalse
\def\cookie@framebgimage{}
\def\cookie@framebgfit{cover}
\def\cookie@framebgopacity{1}
\def\cookie@framebgoverlay{cookieInk}
\def\cookie@framebgoverlayopacity{0}

\define@key{beamerframe}{bgimage}{\global\cookie@backgroundframetrue\gdef\cookie@framebgimage{#1}}
\define@key{beamerframe}{bgfit}{\global\cookie@backgroundframetrue\gdef\cookie@framebgfit{#1}}
\define@key{beamerframe}{bgopacity}{\global\cookie@backgroundframetrue\gdef\cookie@framebgopacity{#1}}
\define@key{beamerframe}{bgoverlay}{\global\cookie@backgroundframetrue\gdef\cookie@framebgoverlay{#1}}
\define@key{beamerframe}{bgoverlayopacity}{\global\cookie@backgroundframetrue\gdef\cookie@framebgoverlayopacity{#1}}

